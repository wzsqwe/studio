{
  "name": "photostudio-pro",
  "version": "1.0.0",
  "description": "自由摄影师全流程经营管理系统",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "cross-env BROWSER=none react-scripts start",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "react-scripts build && electron-builder",
    "build:win": "react-scripts build && electron-builder --win",
    "build:mac": "react-scripts build && electron-builder --mac"
  },
  "build": {
    "appId": "com.photostudio.pro",
    "productName": "PhotoStudio Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "src/main/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "public/icon.png"
    },
    "win": {
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "chart.js": "^4.4.1",
    "electron-log": "^5.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
